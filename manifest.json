{
  "manifest_version": 3,
  "name": "Prompt Vault",
  "version": "1.0.0",
  "description": "Prompt 收纳盒 - 存储、分类、快速复制你的 AI Prompts",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Prompt Vault",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": []
}
